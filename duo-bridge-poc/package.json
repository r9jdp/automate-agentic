{
  "name": "duo-bridge-poc",
  "displayName": "Duo Bridge POC",
  "description": "Verifies command-based integration with GitLab Duo Quick Chat.",
  "version": "0.0.2",
  "private": true,
  "publisher": "local",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onCommand:duoBridge.verify",
    "onCommand:duoBridge.copyAndOpen"
  ],
  "extensionDependencies": [
    "GitLab.gitlab-workflow"
  ],
  "contributes": {
    "commands": [
      {
        "command": "duoBridge.verify",
        "title": "Duo Bridge: Verify Static Send"
      },
      {
        "command": "duoBridge.copyAndOpen",
        "title": "Duo Bridge: Copy Prompt and Open Chat"
      }
    ]
  }
}
